{
    "name": "saas-muhasebe-root",
    "version": "1.0.0",
    "scripts": {
        "dev": "npm run electron-dev --prefix client",
        "install-all": "npm install --prefix client && npm install --prefix jetpos-web && npm install --prefix jetpos-mobile",
        "build": "npm run build:all",
        "build:client": "npm run electron-build --prefix client",
        "build:web": "npm run build --prefix jetpos-web",
        "build:mobile": "npm run build --prefix jetpos-mobile",
